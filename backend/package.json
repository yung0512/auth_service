{
  "name": "simple-auth-service-backend",
  "version": "0.1.0",
  "description": "JWT auth service backend (Express + TypeScript + MySQL + Prisma)",
  "main": "dist/server.js",
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/client": "^6.2.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "winston": "^3.14.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.0",
    "prisma": "^6.2.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.0"
  },
  "allowScripts": {
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true,
    "prisma@6.19.3": true
  }
}
